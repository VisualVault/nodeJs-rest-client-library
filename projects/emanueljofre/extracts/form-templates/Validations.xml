			<Script>// FormValidation for Validation
// pass in ControlName to validate a single item or nothing to validate everything.

var ErrorReporting = true;
var RunAll = false;
if (ControlName == null) {
  RunAll = true;
}

if (ControlName == 'textbox' || RunAll) {
  var valorCampo = VV.Form.GetFieldValue('textbox')
  var tipoVal = 'Blank'
  var esValido = VV.Form.Global.CentralValidation(valorCampo, tipoVal)

  if (!esValido) {
    VV.Form.SetValidationErrorMessageOnField('textbox', 'A value needs to be entered for the textbox.');
    ErrorReporting = false;
  }
  else {
    VV.Form.ClearValidationErrorOnField('textbox');
  }
}

if (ControlName == 'listado' || RunAll) {
  var valorCampo = VV.Form.GetFieldValue('listado')
  var tipoVal = 'DDSelect'
  var esValido = VV.Form.Global.CentralValidation(valorCampo, tipoVal)

  if (!esValido) {
    VV.Form.SetValidationErrorMessageOnField('listado', 'A value needs to be entered for the listado.');
    ErrorReporting = false;
  }
  else {
    VV.Form.ClearValidationErrorOnField('listado');
  }
}

// Return true if there are no errors, false if there are errors.
if (ErrorReporting == false) {
  return false;
} else {
  return true;
}</Script>
