if (ControlName == null) {
    RunAll = true;
}

// city
if (ControlName == 'fieldCity' || RunAll) {
    if (VV.Form.Global.CentralValidation(VV.Form.GetFieldValue('fieldCity'), 'Blank') == false) {
        VV.Form.SetValidationErrorMessageOnField('fieldCity', 'A value needs to be entered.');
        ErrorReporting = false;
    }
    else {
        VV.Form.ClearValidationErrorOnField('fieldCity');
    }
}

// state
if (ControlName == 'fieldState' || RunAll) {
    if (VV.Form.Global.CentralValidation(VV.Form.GetFieldValue('fieldState'), 'Blank') == false) {
        VV.Form.SetValidationErrorMessageOnField('fieldState', 'A value needs to be entered.');
        ErrorReporting = false;
    }
    else {
        VV.Form.ClearValidationErrorOnField('fieldState');
    }
}

return ErrorReporting;</Script>
