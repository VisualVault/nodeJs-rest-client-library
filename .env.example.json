{
    "activeServer": "vvdemo",
    "activeCustomer": "YourCustomerAlias",
    "servers": {
        "vvdemo": {
            "baseUrl": "https://vvdemo.visualvault.com",
            "customers": {
                "YourCustomerAlias": {
                    "customerAlias": "YourCustomerAlias",
                    "databaseAlias": "Main",
                    "clientId": "your-oauth-client-id",
                    "clientSecret": "your-oauth-client-secret",
                    "username": "your.email@company.com",
                    "loginPassword": "your-vv-login-password",
                    "audience": "",
                    "readOnly": false,

                    "_comment_writePolicy": "Optional. Controls which writes are allowed on readOnly environments.",
                    "_comment_writePolicy_modes": "unrestricted (default) | allowlist (only listed resources) | blocked (no writes)",
                    "writePolicy": {
                        "mode": "unrestricted",
                        "forms": [
                            {
                                "templateId": "guid-of-allowed-form",
                                "name": "Human label",
                                "operations": ["create", "update"]
                            }
                        ],
                        "webServices": [{ "name": "AllowedWSName", "scriptId": "optional-id" }],
                        "documents": []
                    }
                }
            }
        }
    }
}
